# ─── Spotify ───────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Set the Redirect URI to: https://localhost
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# No refresh token needed — uses Client Credentials flow (no user login required)

# ─── Telegram ──────────────────────────────────────────────────────────────
# Create a bot via @BotFather and grab the token it gives you
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# The chat/channel ID to send digests to.
# For a personal chat: open https://api.telegram.org/bot<TOKEN>/getUpdates
# after sending any message to the bot — the chat id is in the response.
# For a channel, prefix with -100, e.g. -1001234567890
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Genre filter ──────────────────────────────────────────────────────────
# Preferred: edit genres.json — one genre keyword per line, easy to update.
# Fallback: comma-separated list here (used if genres.json doesn't exist).
# Partial match, case-insensitive. "electronic" matches "electro-pop" etc.
GENRES=jazz,electronic,indie
